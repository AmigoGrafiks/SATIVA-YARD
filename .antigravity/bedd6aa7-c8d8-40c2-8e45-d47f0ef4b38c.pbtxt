  file_change {
    absolute_path_uri: "file:///src/components/Layout.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Link, Outlet, useLocation } from \'react-router-dom\';\nimport { ShoppingBag, Menu, X, Leaf, MapPin, Phone, Mail, Instagram, Facebook } from \'lucide-react\';\nimport { useCart } from \'../context/CartContext\';\nimport { cn } from \'../lib/utils\';\nimport { AnimatePresence, motion } from \'motion/react\';\n\nexport default function Layout() {\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n  const { cartItemCount } = useCart();\n  const location = useLocation();\n\n  const navigation = [\n    { name: \'Home\', href: \'/\' },\n    { name: \'Products\', href: \'/products\' },\n    { name: \'About\', href: \'/about\' },\n    { name: \'Contact\', href: \'/contact\' },\n  ];\n\n  return (\n    <div className=\"flex flex-col min-h-screen bg-white\">\n      {/* Top Banner */}\n      <div className=\"bg-primary text-white text-xs font-medium py-2 px-4 text-center tracking-wide\">\n        PREMIUM CANNABIS LIFESTYLE DESTINATION IN JOHANNESBURG\n      </div>\n\n      {/* Navigation */}\n      <header className=\"sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100\">\n        <nav className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\" aria-label=\"Top\">\n          <div className=\"w-full py-4 flex items-center justify-between\">\n            <div className=\"flex items-center\">\n              <Link to=\"/\" className=\"flex items-center gap-2 group\">\n                <div className=\"bg-primary/10 p-2 rounded-xl group-hover:bg-primary/20 transition-colors\">\n                  <Leaf className=\"h-6 w-6 text-primary\" />\n                </div>\n                <span className=\"font-semibold text-xl tracking-tight text-primary\">SATIVA YARD</span>\n              </Link>\n            </div>\n            \n            <div className=\"hidden md:flex flex-1 justify-center items-center space-x-8\">\n              {navigation.map((link) => (\n                <Link\n                  key={link.name}\n                  to={link.href}\n                  className={cn(\n                    \"text-sm font-medium transition-colors hover:text-primary\",\n                    location.pathname === link.href ? \"text-primary\" : \"text-gray-500\"\n                  )}\n                >\n                  {link.name}\n                </Link>\n              ))}\n            </div>\n\n            <div className=\"flex items-center gap-4\">\n              <Link \n                to=\"/cart\" \n                className=\"relative p-2 text-gray-400 hover:text-primary transition-colors bg-gray-50 rounded-full\"\n              >\n                <ShoppingBag className=\"h-5 w-5\" />\n                {cartItemCount > 0 && (\n                  <span className=\"absolute top-0 right-0 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-bold leading-none text-white transform translate-x-1/4 -translate-y-1/4 bg-primary rounded-full\">\n                    {cartItemCount}\n                  </span>\n                )}\n              </Link>\n              \n              <button\n                type=\"button\"\n                className=\"md:hidden bg-gray-50 p-2 rounded-full text-gray-400 hover:text-primary\"\n                onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n              >\n                <span className=\"sr-only\">Open menu</span>\n                {isMobileMenuOpen ? (\n                  <X className=\"h-5 w-5\" aria-hidden=\"true\" />\n                ) : (\n                  <Menu className=\"h-5 w-5\" aria-hidden=\"true\" />\n                )}\n              </button>\n            </div>\n          </div>\n        </nav>\n\n        {/* Mobile menu */}\n        <AnimatePresence>\n          {isMobileMenuOpen && (\n            <motion.div\n              initial={{ opacity: 0, height: 0 }}\n              animate={{ opacity: 1, height: \'auto\' }}\n              exit={{ opacity: 0, height: 0 }}\n              className=\"md:hidden border-t border-gray-100 bg-white\"\n            >\n              <div className=\"px-4 py-6 space-y-4\">\n                {navigation.map((link) => (\n                  <Link\n                    key={link.name}\n                    to={link.href}\n                    className=\"block text-base font-medium text-gray-900 hover:text-primary\"\n                    onClick={() => setIsMobileMenuOpen(false)}\n                  >\n                    {link.name}\n                  </Link>\n                ))}\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </header>\n\n      {/* Main Content */}\n      <main className=\"flex-grow flex flex-col\">\n        <Outlet />\n      </main>\n\n      {/* Footer */}\n      <footer className=\"bg-white border-t border-gray-100 pt-16 pb-8\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-8\">\n            <div className=\"col-span-1 md:col-span-2 lg:col-span-1\">\n              <Link to=\"/\" className=\"flex items-center gap-2 mb-4\">\n                <Leaf className=\"h-5 w-5 text-primary\" />\n                <span className=\"font-semibold text-lg tracking-tight text-primary\">SATIVA YARD</span>\n              </Link>\n              <p className=\"text-gray-500 text-sm leading-relaxed mb-6\">\n                Redefining the cannabis experience in Johannesburg through premium products, education, and unparalleled customer service.\n              </p>\n              <div className=\"flex gap-4\">\n                <a href=\"#\" className=\"text-gray-400 hover:text-primary transition-colors\">\n                  <Instagram className=\"h-5 w-5\" />\n                </a>\n                <a href=\"#\" className=\"text-gray-400 hover:text-primary transition-colors\">\n                  <Facebook className=\"h-5 w-5\" />\n                </a>\n              </div>\n            </div>\n\n            <div>\n              <h3 className=\"text-sm font-semibold text-gray-900 mb-4 tracking-wider uppercase\">Shop</h3>\n              <ul className=\"space-y-3\">\n                {[\'Cannabis Flower\', \'Pre-Rolls\', \'Concentrates\', \'Edibles\', \'Vapes\', \'Accessories\'].map((item) => (\n                  <li key={item}>\n                    <Link to=\"/products\" className=\"text-gray-500 hover:text-primary text-sm transition-colors\">\n                      {item}\n                    </Link>\n                  </li>\n                ))}\n              </ul>\n            </div>\n\n            <div>\n              <h3 className=\"text-sm font-semibold text-gray-900 mb-4 tracking-wider uppercase\">Company</h3>\n              <ul className=\"space-y-3\">\n                {[\'About Us\', \'Contact\', \'FAQ\', \'Shipping Policy\', \'Privacy Policy\'].map((item) => (\n                  <li key={item}>\n                    <Link to=\"/about\" className=\"text-gray-500 hover:text-primary text-sm transition-colors\">\n                      {item}\n                    </Link>\n                  </li>\n                ))}\n              </ul>\n            </div>\n\n            <div>\n              <h3 className=\"text-sm font-semibold text-gray-900 mb-4 tracking-wider uppercase\">Contact</h3>\n              <ul className=\"space-y-4\">\n                <li className=\"flex items-start gap-3\">\n                  <MapPin className=\"h-5 w-5 text-primary shrink-0\" />\n                  <span className=\"text-sm text-gray-500\">Sandton, Johannesburg<br/>South Africa</span>\n                </li>\n                <li className=\"flex items-center gap-3\">\n                  <Phone className=\"h-5 w-5 text-primary shrink-0\" />\n                  <span className=\"text-sm text-gray-500\">+27 11 000 0000</span>\n                </li>\n                <li className=\"flex items-center gap-3\">\n                  <Mail className=\"h-5 w-5 text-primary shrink-0\" />\n                  <span className=\"text-sm text-gray-500\">hello@sativayard.co.za</span>\n                </li>\n              </ul>\n            </div>\n          </div>\n          \n          <div className=\"mt-16 pt-8 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4\">\n            <p className=\"text-gray-400 text-sm\">\n              &copy; {new Date().getFullYear()} Sativa Yard. All rights reserved. Not for sale to persons under the age of 18.\n            </p>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }
