        target_content: "      {/* Featured Products */}\n      <section className=\"py-24 bg-white\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"flex justify-between items-end mb-12\">\n            <div>\n              <h2 className=\"text-3xl font-bold text-gray-900 tracking-tight mb-2\">Featured Products</h2>\n              <p className=\"text-gray-500\">Discover our most sought-after wellness and lifestyle items.</p>\n            </div>\n            <Link to=\"/products\" className=\"hidden md:inline-flex items-center font-medium text-primary hover:text-primary/80 transition-colors\">\n              View All Collection <ArrowRight className=\"ml-2 h-4 w-4\" />\n            </Link>\n          </div>\n          \n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\">\n            {featuredProducts.map((product) => (\n              <div key={product.id} className=\"group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 flex flex-col\">\n                <div className=\"aspect-square bg-gray-50 relative overflow-hidden\">\n                  <img src={product.image} alt={product.name} className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" />\n                  <div className=\"absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-gray-900 tracking-wide\">\n                    {product.category}\n                  </div>\n                </div>\n                <div className=\"p-6 flex flex-col flex-grow\">\n                  <h3 className=\"text-lg font-bold text-gray-900 mb-1\">{product.name}</h3>\n                  <div className=\"text-xs text-gray-500 mb-4\">{product.strainType} \342\200\242 {product.weight}</div>\n                  <div className=\"mt-auto flex items-center justify-between\">\n                    <spa