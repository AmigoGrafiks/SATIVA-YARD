        <h3 className=\"text-xl font-bold text-gray-900 mb-3\">{feature.title}</h3>\n                <p className=\"text-gray-500 leading-relaxed\">{feature.desc}</p>\n              </motion.div>\n            ))}\n          </div>\n        </div>\n      </section>"
        replacement_content: "      {/* About Section */}\n      <section className=\"py-24 bg-white border-y border-emerald-50\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"grid md:grid-cols-2 gap-16 items-center\">\n            <motion.div \n              initial={{ opacity: 0, x: -20 }}\n              whileInView={{ opacity: 1, x: 0 }}\n              viewport={{ once: true }}\n              className=\"relative\"\n            >\n              <div className=\"aspect-[4/5] rounded-[40px] overflow-hidden relative border border-emerald-50 shadow-sm\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1611078516086-1e626e9de80b?auto=format&fit=crop&q=80&w=1200\" \n                  alt=\"Premium cannabis clinic\" \n                  className=\"w-full h-full object-cover\"\n                />\n                <div className=\"absolute inset-0 bg-emerald-900/10 mix-blend-multiply rounded-[40px]\" />\n              </div>\n            </motion.div>\n            <motion.div\n              initial={{ opacity: 0, x: 20 }}\n              whileInView={{ opacity: 1, x: 0 }}\n              viewport={{ once: true }}\n            >\n              <h2 className=\"text-xs font-bold tracking-[0.2em] text-emerald-600 uppercase mb-4\">About Sativa Yard</h2>\n              <h3 className=\"text-3xl md:text-5xl font-extrabold text-emerald-900 tracking-tight leading-[1.1] mb-6\">\n                Elevating the Standard of Cannabis Wellness.\n              </h3>\n              <p className=\"text-emerald-800/70 mb-8 leading-relaxed text-lg\">\n                We believe in the natural power of cannabis to enhance daily living. As an established lifestyle brand, we are committed to providing meticulously curated products, backed by science and rigorous quality standards.\n              </p>\n              <ul className=\"space-y-4 mb-8\">\n                {[\'Uncompromising Quality Assurance\', \'Expert Curated Selection\', \'Discreet & Professional Service\', \'Community Education Focus\'].map((item) => (\n                  <li key={item} className=\"flex items-center gap-3\">\n                    <div className=\"flex items-center justify-center w-6 h-6 rounded-full bg-emerald-100 text-emerald-700\">\n                       <CheckCircle2 className=\"h-4 w-4\" />\n                    </div>\n                    <span className=\"text-emerald-900 font-bold\">{item}</span>\n                  </li>\n                ))}\n              </ul>\n              <Link to=\"/about\" className=\"inline-flex items-center font-bold text-emerald-700 hover:text-emerald-800 transition-colors uppercase tracking-widest text-sm\">\n                Read our full story <ArrowRight className=\"ml-2 h-4 w-4\" />\n              </Link>\n            </motion.div>\n          </div>\n        </div>\n      </section>\n\n      {/* Why Choose Us */}\n      <section className=\"py-24 bg-gray-50\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"flex justify-between items-end mb-16\">\n            <div>\n              <h2 className=\"text-3xl md:text-4xl font-extrabold text-emerald-900 tracking-tight\">Why Choose Us</h2>\n            </div>\n          </div>\n          <div className=\"grid md:grid-cols-3 gap-8\">\n            {[\n              { icon: Sparkles, title: \'Premium Selection\', desc: \'Carefully curated indoor flowers and artisan products.\', style: \'bg-emerald-100/50 border-emerald-100 text-emerald-900\', iconStyle: \'bg-emerald-700 text-white\' },\n              { icon: ShieldCheck, title: \'Quality Assured\', desc: \'Rigorous lab testing and meticulous sourcing.\', style: \'bg-white border-emerald-50 shadow-sm text-emerald-900\', iconStyle: \'bg-emerald-50 text-emerald-700\' },\n              { icon: Truck, title: \'Fast WhatsApp Ordering\', desc: \'Secure, discreet, and swift delivery across JHB.\', style: \'bg-emerald-900 text-white border-emerald-800\', iconStyle: \'bg-white/20 text-white\' },\n            ].map((feature, i) => (\n              <motion.div \n                key={feature.title}\n                initial={{ opacity: 0, y: 20 }}\n                whileInView={{ opacity: 1, y: 0 }}\n                viewport={{ once: true }}\n                transition={{ delay: i * 0.1 }}\n                className={`p-8 rounded-[32px] border flex flex-col justify-between min-h-[240px] ${feature.style}`}\n              >\n                <div className={`w-12 h-12 rounded-xl flex items-center justify-center mb-6 ${feature.iconStyle}`}>\n                  <feature.icon className=\"h-6 w-6\" />\n                </div>\n                <div>\n                  <h3 className=\"text-xl font-bold mb-3\">{feature.title}</h3>\n                  <p className={`leading-relaxed ${feature.style.includes(\'emerald-900\') ? \'text-emerald-100/70\' : \'text-emerald-800/70\'}`}>{feature.desc}</p>\n                </div>\n              </motion.div>\n            ))}\n          </div>\n        </div>\n      </section>"
