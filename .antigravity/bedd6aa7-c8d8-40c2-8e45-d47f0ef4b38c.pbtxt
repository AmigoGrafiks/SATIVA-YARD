    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { Link } from \'react-router-dom\';\nimport { motion } from \'motion/react\';\nimport { ArrowRight, ShieldCheck, Truck, BookOpen, Star, Sparkles, CheckCircle2 } from \'lucide-react\';\nimport { products } from \'../data\';\nimport { useCart } from \'../context/CartContext\';\n\nexport default function Home() {\n  const { addToCart } = useCart();\n  const featuredProducts = products.filter(p => p.featured);\n\n  return (\n    <div className=\"flex flex-col\">\n      {/* Hero Section */}\n      <section className=\"relative pt-20 pb-24 md:pt-32 md:pb-40 overflow-hidden\">\n        <div className=\"absolute inset-0 z-0\">\n          <div className=\"absolute inset-0 bg-gradient-to-br from-green-50/80 to-white/95 z-10\" />\n          <img \n            src=\"https://images.unsplash.com/photo-1599839619722-39751411ea63?auto=format&fit=crop&q=80&w=2000\" \n            alt=\"Cannabis lifestyle\" \n            className=\"w-full h-full object-cover\"\n          />\n        </div>\n        <div className=\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n          <motion.div\n            initial={{ opacity: 0, y: 20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.6 }}\n            className=\"max-w-3xl mx-auto\"\n          >\n            <span className=\"inline-block py-1 px-3 rounded-full bg-primary/10 text-primary text-sm font-semibold tracking-wider mb-6\">\n              JOHANNESBURG\'S FINEST\n            </span>\n            <h1 className=\"text-4xl md:text-6xl font-bold text-gray-900 tracking-tight mb-6\">\n              Premium Cannabis Lifestyle Destination\n            </h1>\n            <p className=\"text-xl text-gray-600 mb-10 leading-relaxed\">\n              Explore premium cannabis products, wellness solutions, accessories, and education from one of Johannesburg\'s most trusted cannabis lifestyle brands.\n            </p>\n            <div className=\"flex flex-col sm:flex-row gap-4 justify-center\">\n              <Link \n                to=\"/products\"\n                className=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-primary hover:bg-primary/90 rounded-full transition-colors shadow-lg shadow-primary/20\"\n              >\n                Shop Products\n              </Link>\n              <Link \n                to=\"/contact\"\n                className=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-200 rounded-full transition-colors\"\n              >\n                Contact Us\n              </Link>\n            </div>\n          </motion.div>\n        </div>\n      </section>\n\n      {/* About Section */}\n      <section className=\"py-24 bg-white\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"grid md:grid-cols-2 gap-16 items-center\">\n            <motion.div \n              initial={{ opacity: 0, x: -20 }}\n              whileInView={{ opacity: 1, x: 0 }}\n              viewport={{ once: true }}\n              className=\"relative\"\n            >\n              <div className=\"aspect-[4/5] rounded-3xl overflow-hidden relative\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1611078516086-1e626e9de80b?auto=format&fit=crop&q=80&w=1200\" \n                  alt=\"Premium cannabis clinic\" \n                  className=\"w-full h-full object-cover\"\n                />\n                <div className=\"absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl\" />\n              </div>\n            </motion.div>\n            <motion.div\n              initial={{ opacity: 0, x: 20 }}\n              whileInView={{ opacity: 1, x: 0 }}\n              viewport={{ once: true }}\n            >\n              <h2 className=\"text-sm font-semibold tracking-wider text-primary uppercase mb-3\">About Sativa Yard</h2>\n              <h3 className=\"text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6\">\n                Elevating the Standard of Cannabis Wellness.\n              </h3>\n              <p className=\"text-gray-600 mb-8 leading-relaxed text-lg\">\n                We believe in the natural power of cannabis to enhance daily living. As an established lifestyle brand, we are committed to providing meticulously curated products, backed by science and rigorous quality standards.\n              </p>\n              <ul className=\"space-y-4 mb-8\">\n                {[\'Uncompromising Quality Assurance\', \'Expert Curated Selection\', \'Discreet & Professional Service\', \'Community Education Focus\'].map((item) => (\n                  <li key={item} className=\"flex items-center gap-3\">\n                    <CheckCircle2 className=\"h-5 w-5 text-primary shrink-0\" />\n                    <span className=\"text-gray-700 font-medium\">{item}</span>\n                  </li>\n                ))}\n              </ul>\n              <Link to=\"/about\" className=\"inline-flex items-center font-medium text-primary hover:text-primary/80 transition-colors\">\n                Read our full story <ArrowRight className=\"ml-2 h-4 w-4\" />\n              </Link>\n            </motion.div>\n          </div>\n        </div>\n      </section>\n\n      {/* Why Choose Us */}\n      <section className=\"py-24 bg-surface\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n          <h2 className=\"text-3xl font-bold text-gray-900 tracking-tight mb-16\">Why Choose Sativa Yard</h2>\n          <div className=\"grid md:grid-cols-3 gap-8\">\n            {[\n              { icon: Sparkles, title: \'Premium Selection\', desc: \'Carefully curated indoor flowers and artisan products.\' },\n              { icon: ShieldCheck, title: \'Quality Assured\', desc: \'Rigorous lab testing and meticulous sourcing.\' },\n              { icon: Truck, title: \'Fast WhatsApp Ordering\', desc: \'Secure, discreet, and swift delivery across JHB.\' },\n            ].map((feature, i) => (\n              <motion.div \n                key={feature.title}\n                initial={{ opacity: 0, y: 20 }}\n                whileInView={{ opacity: 1, y: 0 }}\n                viewport={{ once: true }}\n                transition={{ delay: i * 0.1 }}\n                className=\"bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow\"\n              >\n                <div className=\"w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary\">\n                  <feature.icon className=\"h-7 w-7\" />\n                </div>\n                <h3 className=\"text-xl font-bold text-gray-900 mb-3\">{feature.title}</h3>\n                <p className=\"text-gray-500 leading-relaxed\">{feature.desc}</p>\n              </motion.div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Featured Products */}\n      <section className=\"py-24 bg-white\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n          <div className=\"flex justify-between items-end mb-12\">\n            <div>\n              <h2 className=\"text-3xl font-bold text-gray-900 tracking-tight mb-2\">Featured Products</h2>\n              <p className=\"text-gray-500\">Discover our most sought-after wellness and lifestyle items.</p>\n            </div>\n            <Link to=\"/products\" className=\"hidden md:inline-flex items-center font-medium text-primary hover:text-primary/80 transition-colors\">\n              View All Collection <ArrowRight className=\"ml-2 h-4 w-4\" />\n            </Link>\n          </div>\n          \n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\">\n            {featuredProducts.map((product) => (\n              <div key={product.id} className=\"group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 flex flex-col\">\n                <div className=\"aspect-square bg-gray-50 relative overflow-hidden\">\n                  <img src={product.image} alt={product.name} className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" />\n                  <div className=\"absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-gray-900 tracking-wide\">\n                    {product.category}\n                  </div>\n                </div>\n                <div className=\"p-6 flex flex-col flex-grow\">\n                  <h3 className=\"text-lg font-bold text-gray-900 mb-1\">{product.name}</h3>\n                  <div className=\"text-xs text-gray-500 mb-4\">{product.strainType} \342\200\242 {product.weight}</div>\n                  <div className=\"mt-auto flex items-center justify-between\">\n                    <span className=\"text-lg font-bold text-primary\">R {product.price}</span>\n                    <button \n                      onClick={() => addToCart(product, 1)}\n                      className=\"bg-gray-900 hover:bg-primary text-white p-2.5 rounded-full transition-colors\"\n                      aria-label=\"Add to cart\"\n                    >\n                      <Sparkles className=\"h-4 w-4\" />\n                    </button>\n                  </div>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Education Section */}\n      <section className=\"py-24 bg-primary text-white overflow-hidden relative\">\n        <div className=\"absolute top-0 right-0 w-1/2 h-full opacity-10 pointer-events-none\">\n          <Leaf className=\"w-full h-full object-cover scale-150 rotate-12 text-white\" />\n        </div>\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n          <div className=\"text-center max-w-2xl mx-auto mb-16\">\n            <BookOpen className=\"h-10 w-10 mx-auto mb-6 text-green-200\" />\n            <h2 className=\"text-3xl font-bold tracking-tight mb-4\">Understanding Cannabis</h2>\n            <p className=\"text-green-50/80 leading-relaxed\">Elevate your experience through education. Learn the fundamental differences between major cannabis profiles.</p>\n          </div>\n          \n          <div className=\"grid md:grid-cols-3 gap-6\">\n            {[\n              { title: \'Sativa\', highlight: \'Energy & Focus\', desc: \'Known for uplifting and cerebral effects. Ideal for daytime use, creative projects, and social gatherings.\' },\n              { title: \'Indica\', highlight: \'Relaxation & Rest\', desc: \'Provides deep physical relaxation. Perfect for evening use, stress relief, and promoting restful sleep.\' },\n              { title: \'Hybrid\', highlight: \'Balanced Harmony\', desc: \'A curated blend of both profiles. Offers a balanced experience customized by specific strain ratios.\' }\n            ].map((edu) => (\n              <div key={edu.title} className=\"bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/10\">\n                <h3 className=\"text-2xl font-bold mb-2\">{edu.title}</h3>\n                <div className=\"text-sm font-semibold text-green-300 tracking-wider uppercase mb-4\">{edu.highlight}</div>\n                <p className=\"text-green-50/80 leading-relaxed\">{edu.desc}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Testimonials */}\n      <section className=\"py-24 bg-white\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n          <h2 className=\"text-3xl font-bold text-gray-900 tracking-tight mb-16\">Client Experiences</h2>\n          <div className=\"grid md:grid-cols-3 gap-8\">\n            {[\n              { name: \'Sarah M.\', role: \'Wellness Advocate\', text: \'The most professional dispensary experience in Johannesburg. The product quality is unmatched.\' },\n              { name: \'David T.\', role: \'Creative Director\', text: \'Clean, modern, and reliable. Their product knowledge helped me find exactly what I needed for daytime focus.\' },\n              { name: \'Jessica L.\', role: \'Yoga Instructor\', text: \'Sativa Yard feels like a premium wellness brand. Delivery is always discreet and perfectly packaged.\' }\n            ].map((review) => (\n              <div key={review.name} className=\"bg-surface p-8 rounded-3xl text-left\">\n                <div className=\"flex text-amber-400 mb-6\">\n                  {[...Array(5)].map((_, i) => <Star key={i} className=\"h-5 w-5 fill-current\" />)}\n                </div>\n                <p className=\"text-gray-700 leading-relaxed mb-6\">\"{review.text}\"</p>\n                <div>\n                  <div className=\"font-bold text-gray-900\">{review.name}</div>\n                  <div className=\"text-sm text-gray-500\">{review.role}</div>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* CTA Section */}\n      <section className=\"py-24 bg-green-50\">\n        <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n          <h2 className=\"text-4xl font-bold text-gray-900 tracking-tight mb-6\">Ready to Explore Premium Cannabis?</h2>\n          <p className=\"text-xl text-gray-600 mb-10\">Discover our full collection of perfectly cultivated flower, handcrafted edibles, and lifestyle accessories.</p>\n          <div className=\"flex flex-col sm:flex-row gap-4 justify-center\">\n            <Link \n              to=\"/products\"\n              className=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-primary hover:bg-primary/90 rounded-full transition-colors\"\n            >\n              Shop Collection\n            </Link>\n            <Link \n              to=\"/contact\"\n              className=\"inline-flex items-center justify-center px-8 py-4 text-base font-medium text-primary bg-white hover:bg-gray-50 border border-primary/20 rounded-full transition-colors shadow-sm\"\n            >\n              Chat on WhatsApp\n            </Link>\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}\n"
    }
