assName=\"h-6 w-6\" />\n                  </div>\n                  <div>\n                    <h3 className=\"font-semibold mb-1\">Email</h3>\n                    <p className=\"text-green-50/80\">hello@sativayard.co.za</p>\n                  </div>\n                </div>\n             </div>\n\n             <div className=\"mt-12 pt-12 border-t border-white/10\">\n                <h3 className=\"font-semibold mb-4\">Business Hours</h3>\n                <div className=\"space-y-2 text-green-50/80\">\n                  <p className=\"flex justify-between\"><span>Monday - Friday</span> <span>09:00 - 18:00</span></p>\n                  <p className=\"flex justify-between\"><span>Saturday</span> <span>10:00 - 16:00</span></p>\n                  <p className=\"flex justify-between\"><span>Sunday</span> <span>Closed</span></p>\n                </div>\n             </div>\n\n             <div className=\"mt-12 flex gap-4\">\n                <a href=\"#\" className=\"bg-white/10 p-3 rounded-full hover:bg-white/20 transition-colors\">\n                  <Instagram className=\"h-5 w-5\" />\n                </a>\n                <a href=\"#\" className=\"bg-white/10 p-3 rounded-full hover:bg-white/20 transition-colors\">\n                  <Facebook className=\"h-5 w-5\" />\n                </a>\n             </div>\n          </div>\n\n          {/* Form */}\n          <div className=\"p-12 md:p-16\">\n            <h2 className=\"text-2xl font-bold text-gray-900 mb-8\">Send a Message</h2>\n            <form className=\"space-y-6\" onSubmit={(e) => e.preventDefault()}>\n              <div>\n                <label htmlFor=\"name\" className=\"block text-sm font-medium text-gray-700 mb-2\">Full Name</label>\n                <input \n                  type=\"text\" \n                  id=\"name\"\n                  className=\"w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all\"\n               